    def collect_model_files(search_paths):
        """Collect and categorize model files from search paths.
        Returns: (functional_models, example_models) as lists of
                 (filename, path, status) tuples where status is
                 model type string or None for yaml errors
        """
        functional_models = []
        example_models = []
        helper_models = []

        for search_path in search_paths:
            if os.path.exists(search_path):
                try:
                    # Check main directory
                    for file in os.listdir(search_path):
                        if file.endswith(('.yaml', '.yml')):
                            full_path = os.path.join(search_path, file)
                            if os.path.isfile(full_path):
                                valid, status = validate_model_file(full_path)
                                if not valid:
                                    continue
                                if 'example' in file.lower():
                                    example_models.append((file, full_path, status))
                                else:
                                    functional_models.append((file, full_path, status))

                    # Check examples subdirectory
                    examples_dir = os.path.join(search_path, 'examples')
                    if os.path.exists(examples_dir) and os.path.isdir(examples_dir):
                        for file in os.listdir(examples_dir):
                            if file.endswith(('.yaml', '.yml')):
                                full_path = os.path.join(examples_dir, file)
                                if os.path.isfile(full_path):
                                    valid, status = validate_model_file(full_path)
                                    if not valid:
                                        continue
                                    example_models.append((file, full_path, status))

                    # Check helpers subdirectory
                    helpers_dir = os.path.join(search_path, 'helpers')
                    if os.path.exists(helpers_dir) and os.path.isdir(helpers_dir):
                        for file in os.listdir(helpers_dir):
                            if file.endswith(('.yaml', '.yml')):
                                full_path = os.path.join(helpers_dir, file)
                                if os.path.isfile(full_path):
                                    helper_models.append((file, full_path, 'helper'))
                except PermissionError:
                    continue

        # Remove duplicates
        seen = set()
        unique_functional = []
        for name, path, status in functional_models:
            if name not in seen:
                seen.add(name)
                unique_functional.append((name, path, status))

        unique_examples = []
        for name, path, status in example_models:
            if name not in seen:
                seen.add(name)
                unique_examples.append((name, path, status))

        unique_helpers = []
        for name, path, status in helper_models:
            if name not in seen:
                seen.add(name)
                unique_helpers.append((name, path, status))

        return unique_functional, unique_examples, unique_helpers

