class MemoryMonitor:
    """Memory usage monitoring class using psutil."""

    def __init__(self):
        self.stats_printed = False
        if not PSUTIL_AVAILABLE:
            self.enabled = False
            return

        self.enabled = True
        self.process = psutil.Process(os.getpid())
        self.start_memory = self.process.memory_info().rss
        self.peak_memory = self.start_memory
        self.start_time = time.time()
        self.phase_memories = {}

    def update_peak(self, phase=None):
        """Update peak memory and optionally record phase memory."""
        if not self.enabled:
            return 0

        current = self.process.memory_info().rss
        self.peak_memory = max(self.peak_memory, current)

        if phase:
            self.phase_memories[phase] = current

        return current

    def get_stats(self):
        """Get comprehensive memory statistics."""
        if not self.enabled:
            return None

        current = self.process.memory_info().rss
        runtime = time.time() - self.start_time

        return {
            'start_mb': self.start_memory / (1024 * 1024),
            'current_mb': current / (1024 * 1024),
            'peak_mb': self.peak_memory / (1024 * 1024),
            'growth_mb': (self.peak_memory - self.start_memory) / (1024 * 1024),
            'runtime_seconds': runtime,
            'phases': {k: v / (1024 * 1024) for k, v in self.phase_memories.items()}
        }

    def print_stats(self):
        """Print memory usage statistics."""
        if self.stats_printed:  # Prevent duplicate printing
            return

        stats = self.get_stats()
        if not stats:
            print("Memory monitoring not available (psutil not installed)")
            return

        print("\n" + "=" * 50)
        print("MEMORY USAGE STATISTICS")
        print("=" * 50)
        print(f"Initial Memory:  {stats['start_mb']:.1f} MB")
        print(f"Peak Memory:     {stats['peak_mb']:.1f} MB")
        print(f"Final Memory:    {stats['current_mb']:.1f} MB")
        print(f"Memory Growth:   {stats['growth_mb']:.1f} MB")
        print(f"Runtime:         {stats['runtime_seconds']:.1f} seconds")

        if stats['phases']:
            print("\nMemory by Phase:")
            for phase, memory in stats['phases'].items():
                print(f"  {phase:<20}: {memory:.1f} MB")
        print("=" * 50)

        self.stats_printed = True  # Mark as printed


