                    f'{args.lab_name}_system_profile.timeline.log'
                )
                verify_timeline_bounds(system_profile, original_start_date, stop_date)

            # Print output files
            print_output_files(bundle_base_dir)

            # For timeline models, cat small profile files to console
            if args.model_type == ModelType.TIMELINE:
                for hostname in bundle_host_list:
                    host_profile = os.path.join(
                        bundle_base_dir, hostname,
                        f'{args.lab_name}_{hostname}_profile.timeline.log'
