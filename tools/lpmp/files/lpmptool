                    model_suffix = f" for {model_info}" if model_info else ""

                    summary_line = (
                        f"Pass {loop_count:<3}     "
                        f"{total_duration} "
                        f"{hostname:<15} timing profile - "
                        f"found {current_pass_patterns} patterns"
