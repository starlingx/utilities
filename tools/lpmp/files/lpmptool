            start_date = auto_start
            args.start_date = auto_start.isoformat()
            if not stop_date:
                stop_date = auto_end
                args.stop_date = auto_end.isoformat()
                args.stop_date_parsed = auto_end
            vlog1(f"Window auto-detected time range: {auto_start} .. {auto_end}")
        else:
            print("Error: No timestamps found in log files for window model",
                  file=sys.stderr)
            sys.exit(1)

    # Get max_time_delta setting - command line overrides model, model overrides default
    # Check if --max-time-delta was explicitly provided by user
    max_time_delta_from_cmdline = '--max-time-delta' in sys.argv
    if max_time_delta_from_cmdline:
        max_time_delta = args.max_time_delta
        vlog2(f"Using max_time_delta from command line: {max_time_delta}")
    else:
        max_time_delta = settings.get('max_time_delta', DEFAULT_MAX_TIME_DELTA)
        vlog2(f"Using max_time_delta from model/default: {max_time_delta}")

    # Store original start_date for bundle mode (each host should start from the same date)
    original_start_date = start_date

    # Define header and banner for all models
    header = (f"Delta(HH:MM:SS)\tHostname{' ' * (HOSTNAME_COLUMN_WIDTH - 8)}\tBlock Label               \t"
              f"Log File{' ' * (LOG_FILE_COLUMN_WIDTH - 8)}\tData")
    banner = (f"-------------\t{'-' * HOSTNAME_COLUMN_WIDTH}\t---------------------------\t"
              f"{'-' * LOG_FILE_COLUMN_WIDTH}\t--------")

    # Window model pre-scan summary
    if is_window_model:
        # Collect file patterns from window blocks
        window_file_patterns = []
        for block in original_blocks:
            if block.get('window'):
                f = block['file']
                if isinstance(f, list):
                    window_file_patterns.extend(f)
                else:
                    window_file_patterns.append(f)

        if bundle_host_list:
            print("\nWindow Model:")
            # Track per-file: hosts, earliest first_ts, latest last_ts
            file_info = {}   # fname -> {'first': ts, 'last': ts}
            file_hosts = {}  # fname -> [hostname, ...]
            skip_info = {}   # fname -> reason
            skip_hosts = {}  # fname -> [hostname, ...]
            total_matched = 0
            total_skipped = 0
            for hostname, dated_dir in zip(bundle_host_list, bundle_host_list_dated):
                host_dir = os.path.join(
                    args.bundle_name, dated_dir, original_logs_dir
                )
                matched, skipped = discover_window_files(
                    host_dir, window_file_patterns, start_date, stop_date
                )
                total_matched += len(matched)
                total_skipped += len(skipped)
                print(f"  {hostname}: {len(matched)} matched"
                      f", {len(skipped)} skipped")
                for fname, first_ts, last_ts in matched:
                    if fname in file_info:
                        if first_ts < file_info[fname]['first']:
                            file_info[fname]['first'] = first_ts
                        if last_ts > file_info[fname]['last']:
                            file_info[fname]['last'] = last_ts
                        file_hosts[fname].append(hostname)
                    else:
                        file_info[fname] = {'first': first_ts, 'last': last_ts}
                        file_hosts[fname] = [hostname]
                for fname, reason in skipped:
                    if fname not in skip_info:
                        skip_info[fname] = reason
                        skip_hosts[fname] = [hostname]
                    else:
                        skip_hosts[fname].append(hostname)

            # Build deduplicated lists sorted by first timestamp
            all_matched = sorted(
                [(f, info['first'], info['last']) for f, info in file_info.items()],
                key=lambda x: x[1]
            )
            # Only show skipped files that were NOT matched on any host
            all_skipped = [
                (f, reason) for f, reason in skip_info.items()
                if f not in file_info
            ]
            # Merge host lists for skipped files into file_hosts
            for fname, hosts in skip_hosts.items():
                if fname not in file_hosts:
                    file_hosts[fname] = hosts

            print()
            print_window_summary(
                all_matched, all_skipped, start_date, stop_date,
                auto_detected=(original_start_date == start_date
                               and '--start-date' not in sys.argv
                               and '-s' not in sys.argv),
                file_hosts=file_hosts
            )
        else:
            print("\nWindow Model:")
            matched, skipped = discover_window_files(
                args.logs_dir, window_file_patterns, start_date, stop_date
            )
            print_window_summary(
                matched, skipped, start_date, stop_date,
                auto_detected=(original_start_date == start_date
                               and '--start-date' not in sys.argv
                               and '-s' not in sys.argv)
            )
        print()

    # Track whether any required block failed (for exit code)
    any_host_failed = False

    # Main processing loop - iterate over bundle hosts if in bundle mode
    if bundle_host_list:
        # Bundle mode - different processing approaches based on model type
        for hostname, dated_dir in zip(bundle_host_list, bundle_host_list_dated):
            # Set logs_dir for this host
            args.logs_dir = os.path.join(args.bundle_name, dated_dir, original_logs_dir)

            # Always show host processing for timeline models, only with verbose for others
            is_timeline_model = (args.model_type == ModelType.TIMELINE)
            if is_timeline_model or get_verbose_level() >= 1:
                print(f"Scanning {hostname} : {args.logs_dir} ", end='', flush=True)

                # Add progress indicator for timeline models
                if is_timeline_model:
                    progress_type = ProgressType(args.progress)
                    progress_active = start_progress_indicator(progress_type)
                else:
                    print()  # New line for non-timeline models

            # Validate logs directory exists for this host
            if not os.path.exists(args.logs_dir):
                print(f"Warning: logs-dir {args.logs_dir} not found for {hostname}, skipping", file=sys.stderr)
                continue

            # Store bundle information for cross-host access
            args.bundle_host_list = bundle_host_list
            args.bundle_host_list_dated = bundle_host_list_dated
            args.original_logs_dir = original_logs_dir

            # Create fresh copies of blocks for this host (deep copy to preserve original patterns)
            blocks = copy.deepcopy(original_blocks)

            # Update hostname variable in bundle mode
            variables['hostname'] = hostname
            # Set current processing hostname for output formatting
            args.current_processing_hostname = hostname

            # Reapply variable substitution with updated hostname
            apply_variable_substitution(blocks, variables)
            # Apply settings variable substitution
            apply_settings_variable_substitution(settings, variables)

            # Timeline models: use original_start_date for consistent processing across hosts
            # Pattern/Pair models: use start_date which may have been advanced from previous processing
            expand_start_date = original_start_date if is_timeline_model else start_date
            expand_wildcards_in_blocks(blocks, args.logs_dir, expand_start_date,
                                       getattr(args, 'stop_date_parsed', None))

            # Update memory monitor for bundle processing
            if memory_monitor:
                memory_monitor.update_peak(f'bundle_host_{hostname}')

            # Reset per-host state
            all_structured_results = []
            pass_summaries = []
            csv_pass_summaries = []
            args.all_optional_warnings = []  # Initialize warnings collection

