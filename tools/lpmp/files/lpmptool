                    )

                    model_info = ""
                    for block in blocks:
                        filenames = block['file'] if isinstance(block['file'], list) else [block['file']]
                        if any(f.startswith('mtcAgent.log') for f in filenames):
                            model_info = extract_model_info(args.logs_dir)
