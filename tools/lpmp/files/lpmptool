        expand_wildcards_in_blocks(blocks, args.logs_dir, start_date,
                                   getattr(args, 'stop_date_parsed', None))

        # Update memory monitor after file expansion
        if memory_monitor:
            memory_monitor.update_peak('file_expansion')

        # Only use model loops setting if user didn't specify -n explicitly and not timeline model
        is_timeline_model = (args.model_type == ModelType.TIMELINE)
        if not is_timeline_model and args.loops == 1 and 'loops' in settings:
            if '-n' not in sys.argv and '--loops' not in sys.argv:
                args.loops = settings['loops']
                vlog2(f"Using loops from model: {args.loops}")

        if args.max_log_length == 180 and 'max_log_length' in settings:
            args.max_log_length = settings['max_log_length']
            vlog2(f"Using max_log_length from model: {args.max_log_length}")

        all_structured_results = []
        pass_summaries = []
        csv_pass_summaries = []
        args.all_optional_warnings = []  # Initialize warnings collection

        # Initialize console capture for system mode
        is_timeline_model = (args.model_type == ModelType.TIMELINE)
        console_capture = ConsoleCapture(silent_mode=is_timeline_model)
        console_capture.start_capture()

        vlog1(f"Loaded {len(blocks)} blocks from {args.model_file}")

        loop_count = 0
        while True:
            loop_count += 1

            # Add model start message for each loop
            model_name = os.path.splitext(os.path.basename(args.model_file))[0]
            if not is_timeline_model:
                if start_date:
                    start_time_str = start_date.strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]
                    print(f"{model_name} Start: {start_time_str}")
                else:
