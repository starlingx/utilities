# This script includes the following operations:
# - Wait until the connection of the OAM floating address.
# - Sync local time from remote HTTP Date header.
# - Get Keystone auth token.
# - Precheck if subcloud already added and delete it if in valid status.
# - Request to add a subcloud for the enrollment.
#

import base64
from email.utils import parsedate_to_datetime
import glob
import os
import subprocess
import sys
import time

import netaddr
import requests
import urllib3

NOCLOUD = "/opt/nocloud"
if NOCLOUD not in sys.path:
    sys.path.insert(0, NOCLOUD)

from nocloud_utils.utils import extract_yaml_value  # noqa: E402
from nocloud_utils.utils import find_file  # noqa: E402
from nocloud_utils.utils import log_error  # noqa: E402
from nocloud_utils.utils import log_info  # noqa: E402

# Suppress InsecureRequestWarning for unverified HTTPS requests
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

USER = "sysadmin"
HOME = f"/home/{USER}"
CONFIG_BASE = f"{HOME}/enroll-config"

DCMANAGER_PORT = 8119
KEYSTONE_PORT = 5000
KEYSTONE_ENDPOINT_RETRY_TIMEOUT_SECONDS = 5 * 60
KEYSTONE_ENDPOINT_RETRY_INTERVAL_SECONDS = 20
OAM_CONNECTION_RETRY_TIMEOUT_SECONDS = 8 * 60
OAM_CONNECTION_RETRY_INTERVAL_SECONDS = 30

# Valid deploy states that allow deletion before re-enrollment.
# Keep in sync with distributedcloud/dcmanager/common/consts.py
VALID_STATES_FOR_DEPLOY_ENROLL = {
    "create-complete",
    "enroll-failed",
    "pre-enroll-failed",
    "pre-init-enroll-failed",
    "init-enroll-failed",
    "factory-restore-complete",
}


class EnrollmentConfig:
    """Container for shared enrollment configuration data."""

    def __init__(self):
        self.bootstrap_values = None
        self.systemcontroller_oam = None
        self.config_dir = None
        self.subcloud_name = None


class BaseClass:
    """Base class for common operations."""

    def __init__(self, config=None):
        if config:
            self.bootstrap_values = config.bootstrap_values
            self.systemcontroller_oam = config.systemcontroller_oam
            self.config_dir = config.config_dir
        else:
            self.bootstrap_values = None
            self.systemcontroller_oam = None
            self.config_dir = self._find_config_dir()

    @property
    def systemcontroller_url(self):
        """Get the system controller URL with proper IPv6 formatting."""
        formatted_ip = (
            f"[{self.systemcontroller_oam}]"
            if netaddr.IPAddress(self.systemcontroller_oam).version == 6
            else self.systemcontroller_oam
        )
        return f"https://{formatted_ip}"

    def _find_config_dir(self):
        """Find the most recent config directory."""
        if not os.path.exists(CONFIG_BASE):
            log_error(f"Config base directory not found: {CONFIG_BASE}")
            sys.exit(1)
        pattern = f"{CONFIG_BASE}/*"
        dirs = [
            d
            for d in sorted(glob.glob(pattern), reverse=True)
            if os.path.isdir(d)
        ]
        if not dirs:
            log_error(f"No config directories found in {CONFIG_BASE}")
            sys.exit(1)
        return dirs[0]

    def find_file_in_config(self, pattern):
        """Find a file matching the pattern."""
        return find_file(pattern, self.config_dir)

    def extract_yaml(self, filepath, key):
        """Extract a value from a YAML file."""
        return extract_yaml_value(filepath, key)

    def load_common_files(self):
        """Load common configuration files and return config object."""
        # Load bootstrap values
        self.bootstrap_values = self.find_file_in_config("*bootstrap-values*")
        if not self.bootstrap_values:
            log_error("bootstrap-values file not found")
            sys.exit(1)
        log_info(f"Found bootstrap-values: {self.bootstrap_values}")

        # Extract systemcontroller_oam_address
        self.systemcontroller_oam = self.extract_yaml(
            self.bootstrap_values, "systemcontroller_oam_address"
        )
        if not self.systemcontroller_oam:
            log_error(
                "systemcontroller_oam_address not found in bootstrap-values"
            )
            sys.exit(1)
        log_info(
            f"Found systemcontroller_oam_address: "
            f"{self.systemcontroller_oam}"
        )

        # Extract subcloud name
        subcloud_name = self.extract_yaml(
            self.bootstrap_values, "name"
        )
        if not subcloud_name:
            log_error("Subcloud name not found in bootstrap-values")
            sys.exit(1)
        log_info(f"Subcloud name: {subcloud_name}")

        # Create and return config object
        config = EnrollmentConfig()
        config.bootstrap_values = self.bootstrap_values
        config.systemcontroller_oam = self.systemcontroller_oam
        config.config_dir = self.config_dir
        config.subcloud_name = subcloud_name
        return config


class SubcloudSetup(BaseClass):
    """Handle subcloud SSL certificate setup."""

    def __init__(self):
        super().__init__()

    def get_ssl_ca_cert_path(self):
        """Get the SSL CA certificate path."""
        if not self.bootstrap_values:
            log_error("bootstrap-values file not found")
            sys.exit(1)

        ssl_ca_cert = self.extract_yaml(self.bootstrap_values, "ssl_ca_cert")
        if not ssl_ca_cert:
            return None
        log_info(f"Searching for ssl_ca_cert file: {ssl_ca_cert}")

        cert_path = os.path.join(self.config_dir, ssl_ca_cert)
        if not os.path.exists(cert_path):
            log_error(f"ssl_ca_cert file not found: {cert_path}")
            sys.exit(1)
        log_info(f"Found ssl_ca_cert file: {cert_path}")

        return cert_path

    def install_ssl_ca(self):
        """Install SSL CA certificate."""
        cert_path = self.get_ssl_ca_cert_path()
        if cert_path:
            log_info(f"Installing SSL CA certificate: {cert_path}")
            try:
                # shell=True required to source openrc file
                cmd = (
                    "source /etc/platform/openrc; "
                    f"system ca-certificate-install {cert_path}"
                )
                subprocess.run(cmd, shell=True, check=True)  # nosec
                log_info("SSL CA certificate installed successfully")
            except subprocess.CalledProcessError as e:
                log_error(f"Failed to install SSL CA certificate: {e}")
                sys.exit(1)

    def execute(self):
        """Execute subcloud setup and return config."""
        config = self.load_common_files()
        self.install_ssl_ca()
        return config


class CentralCloudAuth(BaseClass):
    """Handle authentication with central cloud."""

    def __init__(self, config):
        super().__init__(config)
        self.admin_password = None
        self.auth_token = None

    def load_config_values(self):
        """Load configuration values for authentication."""
        # Extract admin password from bootstrap values
        self.admin_password = self.extract_yaml(
            self.bootstrap_values, "admin_password"
        )
        if not self.admin_password:
            log_error("admin_password not found in bootstrap-values")
            sys.exit(1)
        log_info("Found admin_password")

    def _sync_clock(self, date_header):
        """Sync system clock and hwclock."""
        try:
            subprocess.run(["date", "-s", date_header], check=True)
            log_info("Time synced from remote")
        except subprocess.CalledProcessError as e:
            log_error(f"Failed to sync system time: {e}")

        if os.path.exists("/sbin/hwclock"):
            try:
                subprocess.run(["/sbin/hwclock", "--systohc"], check=True)
                log_info("Hardware clock synced")
            except subprocess.CalledProcessError as e:
                log_error(f"Warning: Failed to sync hardware clock: {e}")

    def sync_time_from_remote(self):
        """Sync local time from remote HTTP Date header with retry."""
        log_info("Attempting to sync time from remote system controller")
        start_time = time.monotonic()
        last_exception = None

        while (
            time.monotonic() - start_time
            < OAM_CONNECTION_RETRY_TIMEOUT_SECONDS
        ):
            try:
                # SSL failure may caused by the CA cert is not valid yet before
                # finishing the clock synchonization, disable the SSL
                # verification in this request. The following Keystone
                # authentication still verifies the SSL.
                # verify=False needed before cert is installed
                response = requests.head(
                    f"{self.systemcontroller_url}:{KEYSTONE_PORT}",
                    verify=False,  # nosec
                    timeout=10,
                )
                if "Date" in response.headers:
                    # Parse HTTP date header to epoch timestamp
                    remote_dt = parsedate_to_datetime(response.headers["Date"])
                    remote_epoch = int(remote_dt.timestamp())
                    current_epoch = int(time.time())

                    diff = remote_epoch - current_epoch
                    abs_diff = abs(diff)
                    if abs_diff > 20:
                        log_info("Updating system time")
                        self._sync_clock(response.headers["Date"])
                    return
            except Exception as e:
                last_exception = e

            interval = OAM_CONNECTION_RETRY_INTERVAL_SECONDS
            log_info(
                f"Remote not ready for time sync, retrying in {interval}s..."
            )
            time.sleep(OAM_CONNECTION_RETRY_INTERVAL_SECONDS)

        log_error(f"Time sync failed after retries: {last_exception}")
        sys.exit(1)

    def get_keystone_auth_token(self):
        """Get Keystone authentication token."""
        keystone_url = f"{self.systemcontroller_url}:{KEYSTONE_PORT}/v3"
        auth_url = f"{keystone_url}/auth/tokens"
        auth_data = {
            "auth": {
                "identity": {
                    "methods": ["password"],
                    "password": {
                        "user": {
                            "name": "admin",
                            "domain": {"name": "Default"},
                            "password": self.admin_password,
                        }
                    },
                },
                "scope": {
                    "project": {"name": "admin", "domain": {"name": "Default"}}
                },
            }
        }
        log_info(f"Requesting auth token from: {auth_url}")
        start_time = time.monotonic()
        last_exception = None
        while (
            time.monotonic() - start_time
            < KEYSTONE_ENDPOINT_RETRY_TIMEOUT_SECONDS
        ):
            try:
                response = requests.post(auth_url, json=auth_data, timeout=30)
                # Raise RequestException if response status_code between 400
                # and 600: https://requests.readthedocs.io/en/latest/api/
                response.raise_for_status()
                self.auth_token = response.headers.get("X-Subject-Token")
                if not self.auth_token:
                    log_error("Auth token not found in response headers")
                    sys.exit(1)
                log_info("Successfully retrieved auth token")
                return self.auth_token
            except requests.exceptions.SSLError as e:
                interval = KEYSTONE_ENDPOINT_RETRY_INTERVAL_SECONDS
                last_exception = e
                log_info(
                    "SSL verification failed, cert may not be ready yet. "
                    f"Retrying in {interval}s..."
                )
                time.sleep(interval)
            except requests.exceptions.RequestException as e:
                log_error(f"Failed to get auth token: {e}")
                sys.exit(1)
        log_error(f"Failed to get auth token after retries: {last_exception}")
        sys.exit(1)

    def execute(self):
        """Execute authentication process."""
        self.load_config_values()
        self.sync_time_from_remote()
        self.get_keystone_auth_token()
        return self.auth_token


class PreEnrollHandler(BaseClass):
    """Check subcloud existence and delete if in a valid state.

    If the subcloud exists with a retriable deploy status, delete it
    before re-enrollment. Block enrollment otherwise.
    """

    def __init__(self, config, auth_token):
        super().__init__(config)
        self.auth_token = auth_token
        self.subcloud_name = config.subcloud_name

    def _get_subcloud(self):
        """GET /v1.0/subclouds/{subcloud_name} with auth header.

        Returns:
            requests.Response or None (if 404)
        """
        url = (
            f"{self.systemcontroller_url}:{DCMANAGER_PORT}"
            f"/v1.0/subclouds/{self.subcloud_name}"
        )
        headers = {"X-Auth-Token": self.auth_token}
        log_info(f"Checking subcloud existence: GET {url}")
        try:
            response = requests.get(
                url, headers=headers, timeout=30
            )
        except requests.exceptions.RequestException as e:
            # Network-level failures (ConnectionError, Timeout, etc.)
            # are fatal. Do not use raise_for_status() as HTTP 404 is
            # expected to be handled below via status code.
            log_error(
                f"Failed to query subcloud "
                f"{self.subcloud_name}: {e}"
            )
            sys.exit(1)
        if response.status_code == 404:
            log_info(
                f"Subcloud {self.subcloud_name} not found, "
                "proceeding to enrollment"
            )
            return None
        if response.status_code != 200:
            # Unexpected HTTP status from dcmanager, e.g. 500
            # Internal Server Error or 401 Unauthorized.
            log_error(
                f"Failed to query subcloud "
                f"{self.subcloud_name}: "
                f"HTTP {response.status_code} "
                f"- {response.text}"
            )
            sys.exit(1)
        return response

    def _delete_subcloud(self):
        """DELETE /v1.0/subclouds/{subcloud_name}."""
        url = (
            f"{self.systemcontroller_url}:{DCMANAGER_PORT}"
            f"/v1.0/subclouds/{self.subcloud_name}"
        )
        headers = {"X-Auth-Token": self.auth_token}
        log_info(f"Deleting subcloud: DELETE {url}")
        try:
            response = requests.delete(
                url, headers=headers, timeout=30
            )
            # Raise RequestException if response status_code between 400
            # and 600: https://requests.readthedocs.io/en/latest/api/
            response.raise_for_status()
            log_info(
                f"Subcloud {self.subcloud_name} "
                "deleted successfully"
            )
        except requests.exceptions.RequestException as e:
            log_error(
                f"Failed to delete subcloud "
                f"{self.subcloud_name}: {e}"
            )
            sys.exit(1)

    def execute(self):
        """Execute pre-enrollment check."""
        response = self._get_subcloud()
        if response is None:
            return
        try:
            deploy_status = response.json().get("deploy-status")
        except (ValueError, KeyError) as e:
            log_error(
                f"Failed to parse response for subcloud "
                f"{self.subcloud_name}: {e}"
            )
            sys.exit(1)
        if deploy_status not in VALID_STATES_FOR_DEPLOY_ENROLL:
            log_error(
                f"Subcloud {self.subcloud_name} exists with "
                f"deploy status '{deploy_status}' which "
                "does not permit deletion before "
                "re-enrollment"
            )
            sys.exit(1)
        self._delete_subcloud()


class SubcloudEnroll(BaseClass):
    """Handle adding subcloud to distributed cloud."""

    def __init__(self, config, auth_token):
        super().__init__(config)
        self.auth_token = auth_token
        self.install_values = None
        self.deploy_config = None
        self.subcloud_name = config.subcloud_name
        self.sysadmin_password = None

    def load_subcloud_config(self):
        """Load subcloud configuration files."""
        # Load install values, install values e.g. boostrap interface
        # and bootstrap vlan is still expected for enrollment
        self.install_values = self.find_file_in_config("*install-values*")
        if not self.install_values:
            log_error("install-values file not found")
            sys.exit(1)
        log_info(f"Found install-values: {self.install_values}")

        # Load deployment config (optional)
        self.deploy_config = self.find_file_in_config("*deploy*")
        if self.deploy_config:
            log_info(f"Found deploy_config: {self.deploy_config}")

        # Extract sysadmin_password from bootstrap values
        self.sysadmin_password = self.extract_yaml(
            self.bootstrap_values, "sysadmin_password"
        )
        if not self.sysadmin_password:
            log_error("sysadmin_password not found in bootstrap-values")
            sys.exit(1)
        log_info("Found sysadmin_password")

    def enroll_subcloud(self):
        """Enroll subcloud via DC Manager API."""
        rpc_url = (
            f"{self.systemcontroller_url}:{DCMANAGER_PORT}/v1.0/subclouds"
        )
        log_info(f"Sending RPC request to: {rpc_url}")

        headers = {"X-Auth-Token": self.auth_token}

        data = {
            "name": self.subcloud_name,
            "bootstrap-address": self.extract_yaml(
                self.bootstrap_values,
                "external_oam_floating_address",
            ),
            "enroll": "true",
            "sysadmin_password": base64.b64encode(
                self.sysadmin_password.encode("utf-8")
            ).decode("utf-8"),
            "on_site": "true",
        }

        files = {}
        try:
            # Prepare multipart form data
            files = {
                "bootstrap_values": (
                    "bootstrap-values.yaml",
                    open(self.bootstrap_values, "rb"),
                    "text/plain",
                ),
                "install_values": (
                    "install-values.yaml",
                    open(self.install_values, "rb"),
                    "text/plain",
                ),
            }

            if self.deploy_config:
                files["deploy_config"] = (
                    "deploy-config.yaml",
                    open(self.deploy_config, "rb"),
                    "text/plain",
                )

            response = requests.post(
                rpc_url, headers=headers, files=files, data=data, timeout=30
            )
            # Raise RequestException if response status_code between 400
            # and 600: https://requests.readthedocs.io/en/latest/api/
            response.raise_for_status()
            log_info(f"Subcloud {self.subcloud_name} added successfully")
            return response.json()
        except requests.exceptions.RequestException as e:
            log_error(f"Failed to add subcloud: {e}")
            sys.exit(1)
        finally:
            # Close file handles
            for file_tuple in files.values():
                file_tuple[1].close()

    def execute(self):
        """Execute subcloud enrollment."""
        self.load_subcloud_config()
        return self.enroll_subcloud()


if __name__ == "__main__":
    config = SubcloudSetup().execute()
    auth_token = CentralCloudAuth(config).execute()
    PreEnrollHandler(config, auth_token).execute()
    SubcloudEnroll(config, auth_token).execute()
