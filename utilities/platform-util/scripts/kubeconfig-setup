# Setups Kubernetes configuration for logged in user.
# No password/token/key is set.
#

# Set Kubernetes config file.
mkdir -p -m 750 "$HOME/.kube"
rm -f "$HOME/.kube/config"
touch "$HOME/.kube/config"
chmod 600 "$HOME/.kube/config"
CERT_AUTH_DATA=$(/usr/local/bin/k8s-ca-read | base64 -w0)
CLUSTER_HOST_IP=$(grep -w controller-cluster-host /etc/hosts | awk '{print $1}')
if [[ $CLUSTER_HOST_IP =~ .*:.* ]]; then
    CLUSTER_HOST_IP="[$CLUSTER_HOST_IP]"
fi
SERVER_URL="https://$CLUSTER_HOST_IP:16443"

# Check if OIDC login config is available
OIDC_CONFIG_FILE="/opt/platform/.oidc_login_config"
SHOULD_CONFIGURE_OIDC_LOGIN=false
if [ -f "$OIDC_CONFIG_FILE" ]; then
    OIDC_CLIENT_ID=$(grep '^oidc-client-id:' "$OIDC_CONFIG_FILE" | awk '{print $2}')
    OIDC_CLIENT_SECRET=$(grep '^oidc-client-secret:' "$OIDC_CONFIG_FILE" | awk '{print $2}')
    OIDC_ISSUER_URL=$(grep '^oidc-issuer-url:' "$OIDC_CONFIG_FILE" | awk '{print $2}')
    OIDC_ISSUER_CA=$(grep '^oidc-issuer-ca:' "$OIDC_CONFIG_FILE" | awk '{print $2}')
    FLOATING_OAM_IP=$(grep -w oamcontroller /etc/hosts | awk '{print $1}')
    if [ -z "$FLOATING_OAM_IP" ]; then
        echo "ERROR: Could not resolve 'oamcontroller' from /etc/hosts. OIDC login will not be configured." >&2
    elif [ -n "$OIDC_CLIENT_ID" ] && [ -n "$OIDC_CLIENT_SECRET" ] && [ -n "$OIDC_ISSUER_URL" ]; then
        if [[ $FLOATING_OAM_IP =~ .*:.* ]]; then
            FLOATING_OAM_IP="[$FLOATING_OAM_IP]"
        fi
        SHOULD_CONFIGURE_OIDC_LOGIN=true
    fi
fi

if [ "$SHOULD_CONFIGURE_OIDC_LOGIN" = true ]; then
    printf "%s\n" \
           "apiVersion: v1" \
           "clusters:" \
           "- cluster:" \
           "    certificate-authority-data: $CERT_AUTH_DATA" \
           "    server: $SERVER_URL" \
           "  name: kubernetes" \
           "contexts:" \
           "- context:" \
           "    cluster: kubernetes" \
           "    user: $USER" \
           "  name: $USER@kubernetes" \
           "- context:" \
           "    cluster: kubernetes" \
           "    user: oidc-login-user" \
           "  name: oidc-login-user@kubernetes" \
           "current-context: $USER@kubernetes" \
           "kind: Config" \
           "preferences: {}" \
           "users:" \
           "- name: $USER" \
           "  user:" \
           "- name: oidc-login-user" \
           "  user:" \
           "    exec:" \
           "      apiVersion: client.authentication.k8s.io/v1" \
           "      command: kubectl" \
           "      args:" \
           "      - oidc-login" \
           "      - get-token" \
           "      - --oidc-issuer-url=${OIDC_ISSUER_URL}" \
           "      - --oidc-client-id=${OIDC_CLIENT_ID}" \
           "      - --oidc-client-secret=${OIDC_CLIENT_SECRET}" \
           "      - --certificate-authority-data=${OIDC_ISSUER_CA}" \
           "      - --oidc-extra-scope=openid,profile,email,groups" \
           "      - --oidc-extra-scope=offline_access" \
           "      - --skip-open-browser" \
           "      - --oidc-redirect-url=http://${FLOATING_OAM_IP}:8000" \
           "      - --listen-address=0.0.0.0:8000" \
           "      interactiveMode: IfAvailable" > "$HOME/.kube/config"
else
    printf "%s\n" \
           "apiVersion: v1" \
           "clusters:" \
           "- cluster:" \
           "    certificate-authority-data: $CERT_AUTH_DATA" \
           "    server: $SERVER_URL" \
           "  name: kubernetes" \
           "contexts:" \
           "- context:" \
           "    cluster: kubernetes" \
           "    user: $USER" \
           "  name: $USER@kubernetes" \
           "current-context: $USER@kubernetes" \
           "kind: Config" \
           "preferences: {}" \
           "users:" \
           "- name: $USER" \
           "  user:" > "$HOME/.kube/config"
fi

# Add or replace KUBECONFIG variable in ".profile" file.
VAR_COUNT=$(grep -cw '^export KUBECONFIG' "$HOME/.profile")
if [[ "$VAR_COUNT" == "0" ]]; then
    echo 'export KUBECONFIG="$HOME/.kube/config"' >> "$HOME/.profile"
else
    sed -i '/^\bexport KUBECONFIG\b/c\export KUBECONFIG="$HOME/.kube/config"' "$HOME/.profile"
fi

